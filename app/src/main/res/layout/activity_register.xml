<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3EFFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registracija"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#2E2442" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="#FFFFFF"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ime"
                android:textSize="12sp"
                android:textColor="#6A6478"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etIme"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:backgroundTint="#6B4EA0"
                android:textColor="#1F1B2A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prezime"
                android:textSize="12sp"
                android:textColor="#6A6478"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPrezime"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:backgroundTint="#6B4EA0"
                android:textColor="#1F1B2A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="12sp"
                android:textColor="#6A6478"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textEmailAddress"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:backgroundTint="#6B4EA0"
                android:textColor="#1F1B2A"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lozinka"
                android:textSize="12sp"
                android:textColor="#6A6478"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="textPassword"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:backgroundTint="#6B4EA0"
                android:textColor="#1F1B2A"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_gravity="center_horizontal"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:text="Kreiraj račun"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6B4EA0" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="Natrag"
                android:textAllCaps="false"
                android:textColor="#6B4EA0"
                android:backgroundTint="#EEE6FF" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>